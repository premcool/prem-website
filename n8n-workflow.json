    {
      "parameters": {
        "fromEmail": "prem@prems.in",
        "toEmail": "prem@prems.in",
        "subject": "={{ `Weekly Blog Post Created: ${$('Format Markdown & Generate Frontmatter').item.json.title}` }}",
        "html": "=<h2>Weekly Blog Post Created Successfully</h2>\n<p><strong>Post Title:</strong> {{ $('Format Markdown & Generate Frontmatter').item.json.title }}</p>\n<p><strong>Filename:</strong> {{ $('Format Markdown & Generate Frontmatter').item.json.filename }}</p>\n<p><strong>Date:</strong> {{ $('Format Markdown & Generate Frontmatter').item.json.date }}</p>\n<p><strong>GitHub URL:</strong> <a href=\"https://github.com/premcool/prem-website/blob/main/content/blog/{{ $('Format Markdown & Generate Frontmatter').item.json.filename }}\">View on GitHub</a></p>\n<p>The blog post has been created and committed to the repository. The site will rebuild automatically if configured with Vercel/Netlify webhooks.</p>",
        "options": {}
      },
