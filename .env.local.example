# Site URL (required for sitemap, RSS feed, and social sharing)
# Update this with your actual domain when deploying
NEXT_PUBLIC_SITE_URL=https://premsaktheesh.com

# GitHub Personal Access Token
# Optional but recommended to avoid API rate limiting
# Create a token at: https://github.com/settings/tokens
# Required scopes: public_repo (or repo for private repos)
GITHUB_TOKEN=your_github_token_here
